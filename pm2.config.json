{
  "name": "ritual-agent",
  "script": "npx tsx src/vps/runner.ts",
  "cwd": "/opt/ritual-agent",
  "instances": 1,
  "exec_mode": "fork",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
  "error_file": "/var/log/ritual-agent/error.log",
  "out_file": "/var/log/ritual-agent/out.log",
  "merge_logs": true,
  "autorestart": true,
  "restart_delay": 5000,
  "max_restarts": 10,
  "min_uptime": "10s",
  "watch": false,
  "kill_timeout": 5000
}
