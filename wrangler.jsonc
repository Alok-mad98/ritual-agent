{
  "name": "ritual-ask",
  "account_id": "ce5d9fa368cff2a89ee8a1fb6b2e7820",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "RITUAL_RPC_URL": "https://rpc.ritualfoundation.org",
    "RITUAL_CHAIN_ID": "1979",
    "GLM_MODEL": "@cf/zai-org/glm-5.2",
    "SOVEREIGN_FACTORY": "0x9dC4C054e53bCc4Ce0A0Ff09E890A7a8e817f304",
    "RITUAL_WALLET": "0x532F0dF0896F353d8C3DD8cc134e8129DA2a3948",
    "CHAT_PAYMENT_ADDRESS": "0x6c4b1131d691a04c39f37ede5834eebde39eb009"
  },
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  // Optional: add a KV namespace for persistent agent state across Worker restarts.
  // Create it first: npx wrangler kv namespace create "AGENT_STATE"
  // Then uncomment the section below and paste the namespace ID.
  // "kv_namespaces": [
  //   {
  //     "binding": "AGENT_STATE",
  //     "id": "your-kv-namespace-id"
  //   }
  // ],
  "observability": {
    "enabled": true
  }
}
